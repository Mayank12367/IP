9.Real-Time Color Detection (Webcam – Yellow)
Code:
import cv2
import numpy as np
import time

cap = cv2.VideoCapture(0)

while True:
    ret, frame = cap.read()
    if not ret:
        break

    frame = cv2.resize(frame, (640, 480))
    blurred = cv2.GaussianBlur(frame, (11, 11), 0)
    hsv = cv2.cvtColor(blurred, cv2.COLOR_BGR2HSV)

    # Color ranges
    colors = {
        "Yellow": ([20, 100, 100], [35, 255, 255], (0,255,255)),
        "Green": ([40, 50, 50], [80, 255, 255], (0,255,0)),
        "Red1": ([0, 120, 70], [10, 255, 255], (0,0,255)),
        "Red2": ([170,120,70], [180,255,255], (0,0,255))
    }

    for name in colors:
        lower = np.array(colors[name][0])
        upper = np.array(colors[name][1])
        color_box = colors[name][2]

        mask = cv2.inRange(hsv, lower, upper)
        kernel = np.ones((5,5), np.uint8)
        mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel)

        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)

        for cnt in contours:
            area = cv2.contourArea(cnt)
            if area > 1000:
                x, y, w, h = cv2.boundingRect(cnt)
                cx = int(x + w/2)
                cy = int(y + h/2)

                cv2.rectangle(frame, (x,y), (x+w,y+h), color_box, 3)
                cv2.circle(frame, (cx,cy), 5, color_box, -1)

                cv2.putText(frame, f"{name}", (x,y-10),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.7, color_box, 2)

                cv2.putText(frame, f"({cx},{cy})", (cx+10,cy),
                            cv2.FONT_HERSHEY_SIMPLEX, 0.6, color_box, 2)

    cv2.imshow("Multi Color Detection", frame)

    key = cv2.waitKey(1) & 0xFF

    # Press 's' to save screenshot
    if key == ord('s'):
        filename = f"screenshot_{int(time.time())}.png"
        cv2.imwrite(filename, frame)
        print("Screenshot Saved:", filename)

    # Press 'q' to quit
    if key == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()

