CODE:
import cv2
import numpy as np
import matplotlib.pyplot as plt

# Load the image (color image)
img = cv2.imread('rgb2gray.jpg')

# Check image
if img is None:
    print("Image not found!")
    exit()

# Convert BGR → RGB for proper display
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# ----------------------------
# LOG TRANSFORMATION
# ----------------------------
img_float = img.astype(np.float32)

c = 255 / np.log(1 + np.max(img_float))
log_img = c * np.log(1 + img_float)
log_img = np.array(log_img, dtype=np.uint8)

# Convert log image BGR → RGB
log_img_rgb = cv2.cvtColor(log_img, cv2.COLOR_BGR2RGB)

# ----------------------------
# PLOT ORIGINAL + LOG + HISTOGRAM
# ----------------------------
plt.figure(figsize=(12, 6))

# Original image
plt.subplot(2, 2, 1)
plt.imshow(img_rgb)
plt.title("Original Image")
plt.axis('off')

# Original histogram
plt.subplot(2, 2, 2)
plt.hist(img_rgb.ravel(), bins=256, color='gray')
plt.title("Original Histogram")

# Log Transformed image
plt.subplot(2, 2, 3)
plt.imshow(log_img_rgb)
plt.title("Log Transformed Image")
plt.axis('off')

# Log Transformed histogram
plt.subplot(2, 2, 4)
plt.hist(log_img_rgb.ravel(), bins=256, color='gray')
plt.title("Log Transformation Histogram")

plt.tight_layout()
plt.show()

3.Histogram of Original and Power-law Transformation.
Code:

import cv2
import numpy as np
import matplotlib.pyplot as plt

# Load image
img = cv2.imread("sample.jpg")

if img is None:
    print("Error: Image not found!")
    exit()

# Convert BGR → RGB
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# Gamma values
gamma_values = [0.1, 0.5, 1.2, 2.2]

plt.figure(figsize=(14, 12))

# ---------- Original Image ----------
plt.subplot(4, 3, 1)
plt.imshow(img_rgb)
plt.title("Original Image")
plt.axis('off')

plt.subplot(4, 3, 2)
plt.hist(img_rgb.ravel(), bins=256, color='gray')
plt.title("Original Histogram")

# ---------- Gamma Images ----------
index = 3     # Start from subplot 3

for gamma in gamma_values:

    # Apply gamma correction
    img_norm = img_rgb / 255.0
    gamma_img = np.power(img_norm, gamma)
    gamma_img = np.uint8(gamma_img * 255)

    # Gamma image
    plt.subplot(4, 3, index)
    plt.imshow(gamma_img)
    plt.axis("off")
    plt.title(f"Gamma = {gamma}")

    # Gamma histogram
    plt.subplot(4, 3, index + 1)
    plt.hist(gamma_img.ravel(), bins=256, color='gray')
    plt.title(f"Histogram γ={gamma}")

    index += 2   # Move to next available slot

plt.tight_layout()
plt.show()

