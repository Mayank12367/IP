import cv2
import numpy as np
import matplotlib.pyplot as plt

# Load grayscale image

gray = cv2.imread('C:/Users/hp/Downloads/lena_gray.bmp', 0)

if gray is None:
    print("Error: Could not load the image.")
    exit()

# Show original image

cv2.namedWindow('Original Image', cv2.WINDOW_NORMAL)
cv2.resizeWindow('Original Image', 350, 350)
cv2.imshow('Original Image', gray)

# Histogram of original image

plt.figure(figsize=(6, 4))
plt.hist(gray.ravel(), bins=256, range=[0, 256],
         color='gray', alpha=0.8)
plt.title('Histogram of Original Image')
plt.xlabel('Pixel Intensity')
plt.ylabel('Frequency')
plt.show()

# Initialize reconstructed images

reconstructed_3bit = np.zeros_like(gray)
reconstructed_4bit = np.zeros_like(gray)

# Colors for bit-plane histograms
colors = ['red', 'green', 'blue', 'orange',
          'purple', 'brown', 'pink', 'black']

# Bit-plane slicing

for i in range(8):

    # Extract bit plane
    bit_plane = (gray >> i) & 1
    bit_plane_img = (bit_plane * 255).astype(np.uint8)

    # Display bit plane
    cv2.namedWindow(f'Bit Plane {i}', cv2.WINDOW_NORMAL)
    cv2.resizeWindow(f'Bit Plane {i}', 300, 300)
    cv2.imshow(f'Bit Plane {i}', bit_plane_img)

    # Colored histogram for bit plane
    plt.figure(figsize=(4, 3))
    plt.hist(bit_plane_img.ravel(),
             bins=256, range=[0, 256],
             color=colors[i], alpha=0.7)
    plt.title(f'Histogram of Bit Plane {i}')
    plt.xlabel('Pixel Intensity')
    plt.ylabel('Frequency')
    plt.show()

    # Image reconstruction

    if i in [4, 5, 6, 7]:   # 4-bit reconstruction
        reconstructed_4bit += bit_plane * (2 ** i)

# Display reconstructed images

