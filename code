PRACTICAL 9

Read and Display a Color Image
Convert Color Spaces (BGR → Gray, HSV, RGB)
Extract a Specific Color (Yellow Detection)
Split and Merge Color Channels
Change Brightness and Contrast
Histogram of Color Image

import cv2
import numpy as np
import matplotlib.pyplot as plt

img = cv2.imread("sample.jpg")
rgb = cv2.cvtColor(img,cv2.COLOR_BGR2RGB)

gray = cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)
hsv = cv2.cvtColor(img,cv2.COLOR_BGR2HSV)

mask = cv2.inRange(hsv,np.array([20,100,100]),np.array([35,255,255]))

b,g,r = cv2.split(img)

bright = cv2.convertScaleAbs(img,alpha=1.5,beta=30)

plt.figure(figsize=(14,10))

plt.subplot(3,3,1); plt.imshow(rgb); plt.title("Original"); plt.axis('off')
plt.subplot(3,3,2); plt.imshow(gray,cmap='gray'); plt.title("Gray"); plt.axis('off')
plt.subplot(3,3,3); plt.imshow(hsv); plt.title("HSV"); plt.axis('off')

plt.subplot(3,3,4); plt.imshow(mask,cmap='gray'); plt.title("Yellow Detection"); plt.axis('off')
plt.subplot(3,3,5); plt.imshow(cv2.cvtColor(bright,cv2.COLOR_BGR2RGB)); plt.title("Brightness"); plt.axis('off')
plt.subplot(3,3,6); plt.imshow(cv2.cvtColor(cv2.merge([b,g,r]),cv2.COLOR_BGR2RGB)); plt.title("Merged"); plt.axis('off')

plt.subplot(3,3,7); plt.imshow(b,cmap='gray'); plt.title("Blue"); plt.axis('off')
plt.subplot(3,3,8); plt.imshow(g,cmap='gray'); plt.title("Green"); plt.axis('off')
plt.subplot(3,3,9); plt.imshow(r,cmap='gray'); plt.title("Red"); plt.axis('off')

plt.tight_layout()
plt.show()

plt.figure()
for i,c in enumerate(('b','g','r')):
    plt.plot(cv2.calcHist([img],[i],None,[256],[0,256]),color=c)

plt.title("Color Histogram")
plt.show()
