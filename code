PRACTICAL 4

Bit Plane Slicing

import cv2
import numpy as np
import matplotlib.pyplot as plt

img = cv2.imread("sample.jpg")
gray = cv2.cvtColor(img,cv2.COLOR_BGR2GRAY)

plt.figure(figsize=(18,6))

plt.subplot(2,9,1)
plt.imshow(gray,cmap='gray')
plt.title("Original")
plt.axis('off')

plt.subplot(2,9,10)
plt.hist(gray.ravel(),256,[0,256])
plt.title("Hist")

for i in range(8):    
    bit = np.bitwise_and(gray,2**i)
    bit = (bit*255).astype(np.uint8)

    plt.subplot(2,9,i+2)
    plt.imshow(bit,cmap='gray')
    plt.title(f"Bit {i}")
    plt.axis('off')

    plt.subplot(2,9,i+11)
    plt.hist(bit.ravel(),256,[0,256])
    plt.title(f"H{i}")

plt.tight_layout()
plt.show()


